# Base URL of the Indian Stock Signals API.
VITE_API_BASE=http://localhost:8000

# Static mode: when "1", the UI loads a bundled predictions.json (no live backend).
# Used by `npm run build:pages` for GitHub Pages. Leave unset for normal API-backed dev.
# VITE_STATIC=1
# Public base path for the built site (GitHub Pages serves under /<repo>/).
# VITE_BASE=/indian-stock-signals/
